{
  "manifest_version": 3,
  "name": "Marketplace Goblin Comp Capture",
  "version": "0.3.0",
  "description": "Capture visible eBay sold/active listings and send comps to Marketplace Goblin.",
  "permissions": ["activeTab", "scripting", "clipboardWrite", "tabs"],
  "host_permissions": [
    "https://www.ebay.com/*",
    "https://ebay.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Marketplace Goblin — Capture eBay comps"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
